# 复制成 .env 并填入你的值；.env 不会提交到仓库（已在 .gitignore 忽略）
# 阿里千问（DashScope / 百炼）——你已有
DASHSCOPE_API_KEY=sk-你的千问key
# 老别名 qwen-flash/plus/max 已无免费额度；用当前代有免费额度的代号
QWEN_MODEL=qwen3.6-flash-2026-04-16

# 火山一句话识别（拿到后再填，接 /asr 用）——4 个一起
VOLC_ASR_APPID=
VOLC_ASR_ACCESS_TOKEN=
VOLC_ASR_ACCESS_SECRET=
VOLC_ASR_CLUSTER=

# 可选：端口、把"今天"固定成 MM-DD（演示用）
PORT=8787
# VL_TODAY=06-16

# 同步骨架（可选）
# NODE_ENV=production   # 生产置 production：/auth/request 不再把 devCode 回给前端
# VL_DATA_DIR=./.data   # 骨架版 JSON 存储目录（换数据库后可删）
